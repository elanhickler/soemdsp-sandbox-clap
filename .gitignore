__pycache__/
*.pyc
*.log
sandbox-preview.png
.python-version
.DS_Store
*.bak
public/presets/useruisettings.json
public/presets/useruisettings.js

# Tauri build output (regenerated by `tauri build`/`cargo build`) -- the
# src-tauri/ project itself (tauri.conf.json, Cargo.toml, src/) is source
# and belongs in the repo. binaries/soemdsp-server-<target-triple>.exe is
# the actual sidecar Tauri's externalBin resolves at build time and stays
# tracked; binaries/dist/ and binaries/work/ are redundant/intermediate
# PyInstaller output from building that sidecar, not needed to run it.
src-tauri/target/
src-tauri/gen/
src-tauri/binaries/work/
src-tauri/binaries/dist/

# CLAP plugin build output (native_modules/-style: .cpp sources are
# committed, compiled .dll/.lib/.pdb are not).
clap-plugin/*.dll
clap-plugin/*.lib
clap-plugin/*.pdb
clap-plugin/*.exp
